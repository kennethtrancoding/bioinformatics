# Anchored to repo root: an unanchored `lib/`/`lib64/` (the standard Python
# template) matches at any depth and was silently excluding the real
# workflow/lib/ package (jobs.py, utils.py, s3_storage.py, ...) from git.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage

# Conda
.conda/
envs/*/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.localized
Thumbs.db

# Project-specific
.bvbrc_token
results/*/
data/raw_fastq/
# Per-job runtime state: sample manifests, checksums, endpoint overrides, and
# BV-BRC tokens written under config/jobs/<JOB_ID>/ at upload/run time. The
# .bvbrc_token rule above only matched the token by basename; the manifest and
# overrides sitting next to it were untracked by any rule.
config/jobs/
logs/
*.txt.gz
*.fastq.gz
*.fasta.gz

# Sensitive
*.credentials
*.env
.env.local

# Test/scratch files
scratch_*.py
*_test.py
