# Every environment variable the app reads. Copy to /etc/bioinformatics/app.env
# on the EC2 host, fill in the real values, and `sudo chmod 600` it.
#
#   sudo mkdir -p /etc/bioinformatics
#   sudo cp deploy/app.env.example /etc/bioinformatics/app.env
#   sudo chmod 600 /etc/bioinformatics/app.env
#
# This file is read by deploy/bioinformatics.service (systemd EnvironmentFile).
# Do NOT commit the filled-in version -- it holds secrets.

# --- Which image systemd runs (built locally by `docker build`) --------------
IMAGE=bioinformatics-pipeline:latest

# --- Access control ---------------------------------------------------------
# Setting APP_PASSWORD turns on site-wide HTTP Basic Auth. Leave it UNSET only
# for local development -- an unset password means the app is fully open, and
# job IDs are the sole thing gating access to genomic results.
APP_USERNAME=mentor
APP_PASSWORD=

# Flask session signing key. MUST be set in production: when unset the app falls
# back to os.urandom(32), which is regenerated on every restart.
# Generate with:  openssl rand -hex 32
SECRET_KEY=

# Number of reverse proxies in front of the app. Set to 1 for the standard
# deployment, where Caddy terminates TLS and proxies to the container
# (deploy/caddy.md). Without it every request looks like it came from the proxy
# itself, and the per-IP rate limit on job-ID lookups becomes one bucket shared
# by all users. Leave UNSET (0) when running the app with nothing in front of it
# -- trusting a hop that doesn't exist lets a client forge its own source IP via
# X-Forwarded-For and evade the limit entirely.
TRUSTED_PROXY_HOPS=1

# --- Durable result storage (S3) --------------------------------------------
# When RESULTS_S3_BUCKET is set, finished jobs are uploaded to S3 and the
# view/download routes fall back to S3 after local results are pruned (3h after
# first view / 7d after completion). Leave UNSET to keep everything local-only,
# in which case results are gone for good once the retention sweep runs.
# Credentials come from the EC2 instance's IAM role -- never put AWS keys here.
RESULTS_S3_BUCKET=kennethtrancoding-bioinformatics-bucket
RESULTS_S3_PREFIX=results
# Lifetime of the presigned download URLs handed to the browser, in seconds.
RESULTS_S3_PRESIGN_SECONDS=300

# --- Pipeline concurrency ---------------------------------------------------
# Budget roughly MAX_CONCURRENT_PIPELINES x PIPELINE_CORES cores, plus a few GB
# of RAM per slot (RGI holds the CARD database in memory for a whole run).
# Runs beyond the cap queue FIFO rather than overloading the host.
#
# This is a count of *whole pipelines*, and each one gets its own Snakemake with
# its own pools -- they do not share a budget and divide it. Two concurrent runs
# on this box therefore demand 2 x PIPELINE_CORES cores from the 2 it has, hold
# two copies of the CARD database in 7.6 GB of RAM with no swap, and put
# 2 x BVBRC_MAX_IN_FLIGHT samples in BV-BRC's queue -- where bvbrc.max_wait_time
# (2h, config.yaml) is the point a queued sample stops waiting and FAILS.
#
# So on a 2-vCPU host this is 1. A second run does not make the batch finish
# sooner; it makes both runs thrash, and can fail them. Raise it only with the
# cores and the RAM to back it.
MAX_CONCURRENT_PIPELINES=1

# The cores this box has. Bounds the rules that actually compute (RGI, BLAST,
# MobileElementFinder), and nothing else. Because RGI and MEF each take the whole
# pool, the local half of a run is linear in sample count -- so on a big batch this
# is the number that decides how long it takes, and the only one worth raising.
#
# Set it to the box's real vCPU count. Raising it above that buys nothing: the app
# clamps it to the cores that actually exist, because a compute rule that asks for
# more threads than the box has does not run slower -- RGI refuses to start at all,
# and takes an already hour-deep run down with it. m7i-flex.large is 2.
PIPELINE_CORES=2

# How many samples may be assembling at BV-BRC at once. NOT a hardware limit: the
# 40-60 minute assembly runs on BV-BRC's cluster and costs this box a poll loop and
# a few tens of MB. Sized for the batch, so a batch this size or smaller assembles
# in ONE round instead of ceil(N / PIPELINE_CORES) rounds.
#
# Before raising it: BV-BRC's queue is not free. More jobs queued there at once means
# each sits longer, and config.yaml's bvbrc.max_wait_time (2h) is where the poll gives
# up and the sample FAILS -- so raise that alongside this, or you will turn their queue
# time into timeouts. And each in-flight sample is a live poll process here, so a few
# hundred is gigabytes of idle Python.
BVBRC_MAX_IN_FLIGHT=12

# How many samples may hold raw FASTQ on local disk at once while feeding it to
# BV-BRC. Peak raw disk is this many read pairs, not the whole batch's -- reads live
# on S3 and are pulled back only for the upload (workflow/rules/raw.smk). Keep it
# small; raising it buys little (the upload is minutes, the assembly is an hour) and
# costs disk.
BVBRC_UPLOAD_BATCH=4

# --- Runtime estimates ------------------------------------------------------
# The model behind the "starts in ..." / "... left" times on the page. A fresh
# instance uses these as written until its own finished runs correct them.
#
# Both defaults are MEASURED, from a 48-sample run (see workflow/lib/run_estimates.py).
# Leave them alone unless you change what the pipeline does locally, and if you do,
# re-measure from a real run rather than guessing -- the guessed values these replaced
# were 6x too high and quoted a 5-hour batch as 30 hours.
# RUN_REMOTE_SECONDS=4000               # genus + BV-BRC assembly, per ROUND of
#                                       # BVBRC_MAX_IN_FLIGHT samples -- not per sample
# RUN_LOCAL_CORE_SECONDS_PER_SAMPLE=600 # RGI/BLAST/MLST/MEF/reports, in CORE-seconds
#                                       # per sample -- divided by PIPELINE_CORES
#
# Note what these say about where the time goes: a batch of this size is bound by
# BV-BRC, not by this box. Cores cut the local term only, and it is the small one --
# 48 samples is ~5.4h on 2 cores and ~4.7h on 8. If you want a batch to finish sooner,
# BVBRC_MAX_IN_FLIGHT is the knob, not PIPELINE_CORES (read its warning first).

# --- Cloud imports (OneDrive / Google Drive share links) --------------------
# Users can paste a share link and have the *server* pull the FASTQ files. Both
# credentials below are optional and read-only; leave them unset and the feature
# still works for single-file Drive links and consumer OneDrive links.
#
# Needed to list a Google Drive FOLDER (impossible anonymously). Create an API
# key in a Google Cloud project with the Drive API enabled, and restrict it to
# that API. Without it, only links to a single Drive file can be imported.
# GOOGLE_DRIVE_API_KEY=
#
# Needed for OneDrive for Business / SharePoint links, which cannot be read
# anonymously. Consumer OneDrive (1drv.ms, onedrive.live.com) links do not need
# it. A Microsoft Graph token with Files.Read.All.
# MS_GRAPH_ACCESS_TOKEN=

# Server-side pulls running at once. Each is a long download of someone else's
# data, so the cap keeps a handful of links from saturating the host's bandwidth
# and disk while a pipeline run is trying to use them. Further requests get 429.
# Cloud import is currently disabled (the /cloud-import routes are commented out
# in frontend.py), so this is not read by anything.
# MAX_CONCURRENT_CLOUD_IMPORTS=2

# Size limits for one import. Defaults are far above a real sequencing run (a
# bacterial isolate pair is ~1 GB gzipped) and exist to bound a mistaken or
# hostile link, not normal use. Over the per-file cap the file is skipped with a
# warning; over the total cap the import is aborted.
# CLOUD_IMPORT_MAX_FILE_BYTES=21474836480
# CLOUD_IMPORT_MAX_TOTAL_BYTES=214748364800
# CLOUD_IMPORT_MAX_FILES=500

# Comma-separated extra *content* hosts to accept on a redirect hop, if a
# provider starts serving downloads from a host this app does not know about.
# It does NOT widen what counts as a share link -- an entry URL must still be
# Google Drive or OneDrive/SharePoint.
# CLOUD_IMPORT_ALLOWED_HOSTS=

# --- Optional ---------------------------------------------------------------
# Comma-separated extra hostnames accepted as API endpoint overrides on the
# per-job Settings page. Only needed if you point jobs at a non-default BV-BRC.
# ALLOWED_API_HOSTS=
