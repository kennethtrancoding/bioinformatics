# Every environment variable the app reads. Copy to /etc/bioinformatics/app.env
# on the EC2 host, fill in the real values, and `sudo chmod 600` it.
#
#   sudo mkdir -p /etc/bioinformatics
#   sudo cp deploy/app.env.example /etc/bioinformatics/app.env
#   sudo chmod 600 /etc/bioinformatics/app.env
#
# This file is read by deploy/bioinformatics.service (systemd EnvironmentFile).
# Do NOT commit the filled-in version -- it holds secrets.

# --- Which image systemd runs (built locally by `docker build`) --------------
IMAGE=bioinformatics-pipeline:latest

# --- Access control ---------------------------------------------------------
# Setting APP_PASSWORD turns on site-wide HTTP Basic Auth. Leave it UNSET only
# for local development -- an unset password means the app is fully open, and
# job IDs are the sole thing gating access to genomic results.
APP_USERNAME=mentor
APP_PASSWORD=

# Flask session signing key. MUST be set in production: when unset the app falls
# back to os.urandom(32), which is regenerated on every restart.
# Generate with:  openssl rand -hex 32
SECRET_KEY=

# --- Durable result storage (S3) --------------------------------------------
# When RESULTS_S3_BUCKET is set, finished jobs are uploaded to S3 and the
# view/download routes fall back to S3 after local results are pruned (3h after
# first view / 7d after completion). Leave UNSET to keep everything local-only,
# in which case results are gone for good once the retention sweep runs.
# Credentials come from the EC2 instance's IAM role -- never put AWS keys here.
RESULTS_S3_BUCKET=kennethtrancoding-bioinformatics-bucket
RESULTS_S3_PREFIX=results
# Lifetime of the presigned download URLs handed to the browser, in seconds.
RESULTS_S3_PRESIGN_SECONDS=300

# --- Pipeline concurrency ---------------------------------------------------
# Budget roughly MAX_CONCURRENT_PIPELINES x PIPELINE_CORES cores, plus a few GB
# of RAM per slot (RGI holds the CARD database in memory for a whole run).
# Runs beyond the cap queue FIFO rather than overloading the host.
MAX_CONCURRENT_PIPELINES=2
PIPELINE_CORES=4

# --- Optional ---------------------------------------------------------------
# Comma-separated extra hostnames accepted as API endpoint overrides on the
# per-job Settings page. Only needed if you point jobs at a non-default BV-BRC.
# ALLOWED_API_HOSTS=
