{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "ListBucket",
			"Effect": "Allow",
			"Action": "s3:ListBucket",
			"Resource": "arn:aws:s3:::kennethtrancoding-bioinformatics-bucket"
		},
		{
			"Sid": "ReadWriteResultsObjects",
			"Effect": "Allow",
			"Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
			"Resource": "arn:aws:s3:::kennethtrancoding-bioinformatics-bucket/results/*"
		},
		{
			"Sid": "ReadWriteRawUploads",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:DeleteObject",
				"s3:GetObjectTagging",
				"s3:PutObjectTagging"
			],
			"Resource": "arn:aws:s3:::kennethtrancoding-bioinformatics-bucket/raw/*"
		}
	]
}
